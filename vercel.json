{
  "functions": {
    "src/app/api/events/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/articles/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=30" }
      ]
    }
  ]
}
